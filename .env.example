# Browser-visible feature selection. This is configuration, never a credential.
VITE_BITEBUDDY_AI_MODE=mock_ai
VITE_BITEBUDDY_AI_TIMEOUT_MS=50000

# Server-only provider selection. Gemini is used only when selected explicitly.
AI_PROVIDER_MODE=mock
BITEBUDDY_API_HOST=127.0.0.1
BITEBUDDY_API_PORT=8787
BITEBUDDY_PROVIDER_TIMEOUT_MS=3000

# Server-only Gemini configuration. Never prefix the API key with VITE_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_MS=45000
