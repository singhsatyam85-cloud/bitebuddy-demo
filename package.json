{
  "name": "bitebuddy-food-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env scripts/dev.mjs",
    "dev:frontend": "vite --host 127.0.0.1 --strictPort",
    "dev:backend": "node --env-file-if-exists=.env server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:ai": "node --test tests/*.test.js",
    "test:gemini-live": "node --env-file-if-exists=.env scripts/test-gemini-live.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
